{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "cknow/laravel-money": "^8.4",
        "cviebrock/eloquent-sluggable": "^11.0.1",
        "darryldecode/cart": "^4.2.5",
        "hashids/hashids": "^5.0.2",
        "honeystone/laravel-seo": "^1.4.1",
        "jantinnerezo/livewire-alert": "^3.0.3",
        "laravel/framework": "^11.45.1",
        "laravel/helpers": "^1.7.2",
        "laravel/nightwatch": "^1.7.2",
        "laravel/tinker": "^2.10.1",
        "laravel/ui": "^4.6.1",
        "laraveldaily/laravel-charts": "^0.2.3",
        "livewire/livewire": "^3.6.3",
        "opcodesio/log-viewer": "^3.17.1",
        "spatie/laravel-medialibrary": "^11.13.0",
        "spatie/laravel-sitemap": "^7.3.6",
        "yajra/laravel-datatables-oracle": "^11.1.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "laravel/boost": "^1.0",
        "laravel/pint": "^1.22.1",
        "laravel/sail": "^1.43.1",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.8.1",
        "phpunit/phpunit": "^11.5.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
